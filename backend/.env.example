# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/svem

# JWT Authentication
JWT_SECRET=super_secret_access_token_key_123!
JWT_REFRESH_SECRET=super_secret_refresh_token_key_456!
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Nodemailer configuration (for OTP and PDF invoices)
# To test locally, you can use Etheral email service or Gmail SMTP
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=mock_user@ethereal.email
SMTP_PASS=mock_password
SMTP_FROM="Sri Venkateshwara Oil Mill <noreply@svem.com>"

# Twilio SMS & WhatsApp configuration
# Set these to enable real notifications, otherwise mock logs will be used
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Razorpay credentials
# Use test mode keys for development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary configuration (for product image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin Configuration
ADMIN_EMAIL=shreedhana2005@gmail.com
