# ============================================================
# Sri Venkateshwara Oil Mill — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=5000
NODE_ENV=development   # development | production

# -----------------------------------------------------------
# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# -----------------------------------------------------------
# JWT — Legacy / custom tokens (keep even if using Supabase Auth)
# -----------------------------------------------------------
JWT_SECRET=replace-with-strong-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-strong-random-string
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------
# Email — Nodemailer (SMTP)
# For development, leave as ethereal.email and the server will
# auto-create a free test account and print the preview URL.
# For production, use a real SMTP provider (e.g. SendGrid, Mailgun).
# -----------------------------------------------------------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false        # true if using port 465
SMTP_USER=mock_user@ethereal.email
SMTP_PASS=mock_password
SMTP_FROM="Sri Venkateshwara Oil Mill <noreply@svem.com>"

# -----------------------------------------------------------
# Twilio — SMS & WhatsApp (optional, leave blank to simulate)
# Get from: https://console.twilio.com
# -----------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# -----------------------------------------------------------
# Razorpay — Payments (optional, leave blank to use simulator)
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# -----------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret

# -----------------------------------------------------------
# Cloudinary — Image uploads (optional, leave blank to skip uploads)
# Get from: https://console.cloudinary.com
# -----------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -----------------------------------------------------------
# Application config
# -----------------------------------------------------------
ADMIN_EMAIL=shreedhana2005@gmail.com
FRONTEND_URL=http://localhost:5173
